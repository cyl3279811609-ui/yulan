# MongoDB 连接字符串
# 本地开发
MONGODB_URI=mongodb://localhost:27017/yulan

# 云端 MongoDB Atlas（需要替换用户名和密码）
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/yulan?retryWrites=true&w=majority

# JWT 密钥（生产环境需要更改为强随机密钥）
JWT_SECRET=your-secret-key-change-in-production

# 服务器端口
PORT=5000

# 环境变量
NODE_ENV=development

# 前端 URL（用于 CORS）
FRONTEND_URL=http://localhost:3000
